{
    "name": "togul/php-sdk",
    "description": "PHP SDK for Togul Feature Flag Service",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Togul\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Togul\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests"
    },
    "minimum-stability": "stable",
    "version": "3.0.0"
}
